# Casa Avenida — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git

# Google Maps (domain-restricted to casaavenidadelray.com in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# Resend (email delivery for contact form)
RESEND_API_KEY=

# Google Sheets (lead logging webhook)
GOOGLE_SHEETS_WEBHOOK_URL=

# MailerLite (newsletter subscribe)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# reCAPTCHA v3
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Virtual Tour iframe URL (from team — leave empty until provided)
NEXT_PUBLIC_VIRTUAL_TOUR_URL=
